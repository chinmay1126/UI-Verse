{
  "ci": {
    "collect": {
      "staticDistDir": ".",
      "url": [
        "/index.html",
        "/button.html",
        "/cards.html",
        "/loaders.html",
        "/toggles.html",
        "/navbar.html"
      ],
      "numberOfRuns": 3
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", {"minScore": 0.9}],
        "categories:accessibility": ["error", {"minScore": 0.9}]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
