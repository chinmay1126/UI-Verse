{
  "stickyOffset": 80,
  "enableProgress": true,
  "enableKeyboard": true,
  "enableSectionCount": true,
  "smoothScroll": true,

  "navigation": {
    "position": "top",
    "autoHide": false,
    "mobileBreakpoint": 768,
    "showIcons": false,
    "showLabels": true
  },

  "scrollBehavior": {
    "duration": 400,
    "offset": 80,
    "easing": "easeInOut"
  },

  "observer": {
    "threshold": 0.4,
    "rootMargin": "-80px 0px -40% 0px"
  },

  "progress": {
    "enabled": true,
    "height": 4,
    "showPercentage": false
  },

  "keyboard": {
    "enabled": true,
    "nextKey": "ArrowRight",
    "previousKey": "ArrowLeft",
    "firstKey": "Home",
    "lastKey": "End"
  },

  "mobile": {
    "enabled": true,
    "collapsible": true,
    "defaultOpen": false
  },

  "analytics": {
    "enabled": true,
    "trackClicks": true,
    "trackSectionChanges": true
  },

  "accessibility": {
    "ariaLabels": true,
    "focusManagement": true,
    "screenReaderSupport": true
  },

  "theme": {
    "inheritProjectTheme": true,
    "darkModeSupport": true
  },

  "animations": {
    "enabled": true,
    "duration": 200
  }
}