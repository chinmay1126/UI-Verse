  "componentDefaults": {
    "button": {
      "borderRadius": "8px",
      "padding": "12px 24px",
      "fontSize": "14px",
      "fontWeight": "600",
      "transition": "0.25s cubic-bezier(0.4, 0, 0.2, 1)"
    },
    "card": {
      "borderRadius": "14px",
      "padding": "24px",
      "boxShadow": "0 4px 6px -1px rgba(0, 0, 0, 0.1)"
    },
    "input": {
      "borderRadius": "8px",
      "padding": "12px 16px",
      "fontSize": "14px",
      "borderWidth": "1px"
    },
    "badge": {
      "borderRadius": "9999px",
      "padding": "4px 12px",
      "fontSize": "12px",
      "fontWeight": "600"
    },
    "navbar": {
      "height": "64px",
      "padding": "0 24px"
    },
    "sidebar": {
      "width": "240px"
    }
